<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="cellRootAnkerPane" prefHeight="90.0" prefWidth="400.0" style="-fx-background-color: B5E18B;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <ImageView fx:id="cellImageView" fitHeight="48.0" fitWidth="50.0" layoutX="14.0" layoutY="21.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../assets/icons8-tasks-48.png" />
         </image>
      </ImageView>
      <Label fx:id="cellTaskLabel" layoutX="70.0" layoutY="4.0" prefHeight="20.0" prefWidth="318.0" style="-fx-background-color: F0FFC2;" text="Task">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label fx:id="cellTaskDescription" layoutX="70.0" layoutY="30.0" prefHeight="30.0" prefWidth="318.0" style="-fx-background-color: F0FFC2;" text="Desciprion" wrapText="true">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label fx:id="cellDateLabel" alignment="CENTER_RIGHT" layoutX="70.0" layoutY="66.0" prefHeight="20.0" prefWidth="170.0" style="-fx-background-color: EAE6BC;" text="Date Created">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <ImageView fx:id="cellDeleteButton" fitHeight="30.0" fitWidth="22.0" layoutX="355.0" layoutY="65.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../assets/icons8-remove-100.png" />
         </image>
      </ImageView>
      <ImageView fx:id="editImageButtonCell" fitHeight="30.0" fitWidth="22.0" layoutX="324.0" layoutY="65.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../assets/icons8-edit-50.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
