                  <Font size="18.0" />
               </font>
            </Label>
            <ImageView fx:id="listImageViewRefresh" fitHeight="22.0" fitWidth="20.0" layoutX="612.0" layoutY="59.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../assets/icons8-refresh-30.png" />
               </image>
            </ImageView>
            <Label alignment="CENTER_RIGHT" layoutX="632.0" layoutY="55.0" prefHeight="27.0" prefWidth="36.0" text="reset" textFill="#e4dfb5">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
         </children>
      </AnchorPane>
      <JFXListView fx:id="listTasksView" layoutX="242.0" layoutY="93.0" prefHeight="294.0" prefWidth="448.0">
