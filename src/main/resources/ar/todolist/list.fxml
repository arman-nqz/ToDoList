            </JFXTextField>
            <JFXButton fx:id="listSaveTaskButton" layoutX="65.0" layoutY="241.0" prefHeight="47.0" prefWidth="109.0" style="-fx-background-color: #28396C;" text="Save Task" textFill="WHITE">
